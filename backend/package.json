    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@inventari/shared": "*",
    "@supabase/supabase-js": "^2.49.1",
    "bcrypt": "^6.0.0",
    "dejavu-fonts-ttf": "^2.37.3",
    "docx": "^9.7.1",
    "dotenv": "^17.2.0",
    "exceljs": "^4.4.0",
    "fastify": "^5.4.0",
    "google-auth-library": "^10.7.0",
    "pdfkit": "^0.19.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "pg": "^8.22.0",
    "tsx": "^4.20.5",
    "typescript": "~6.0.2",
