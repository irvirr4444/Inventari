# Root env is optional. For local dev you can keep separate envs:
# - backend/.env (server-only secrets)
# - frontend/.env (public config)
#
# If you keep a root .env, make sure it is NOT committed.

# Supabase (server)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Backend
PORT=3001
CORS_ORIGIN=http://localhost:5173
login_email=
login_password=
SESSION_SECRET=replace-with-at-least-32-random-characters
GOOGLE_CLIENT_ID=

# Optional: Postgres URI (Supabase Dashboard > Database > Connection string)
# Used by: npm run apply:tenant-migrations -w backend
DATABASE_URL=

# Frontend (Vite reads repo root via frontend/vite.config.ts envDir)
VITE_API_BASE_URL=/api
VITE_GOOGLE_CLIENT_ID=
